{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Clone": {
    "EnvironmentName": "Development",
    "Docker": {
      "ContainerName": "sqlclone-local",
      "Image": "mcr.microsoft.com/mssql/server:2022-latest",
      "HostPort": 14333,
      "SaPassword": "YourStrong!Passw0rd",
      "RemoveVolumeOnTeardown": false
    },
    "Source": {
      "ConnectionString": "Server=tcp:your-source-server.database.windows.net,1433;Initial Catalog=master;User ID=source_user;Password=source_password;Encrypt=True;TrustServerCertificate=False;",
      "Encrypt": true,
      "TrustServerCertificate": false,
      "DisableConnectionPooling": false
    },
    "Restore": {
      "Materializer": "CreateEmpty",
      "Databases": [
        "AppDb",
        "ReportingDb"
      ],
      "AzureBackup": {
        "BackupUrlTemplate": "https://yourstorage.blob.core.windows.net/sql-backups/{sourceServer}/{database}.bak",
        "SharedAccessSignature": "",
        "SqlCredentialName": "SqlCloneAzureBackupSas"
      }
    },
    "LinkedServers": {
      "Definitions": [
        {
          "Name": "REMOTEDEV",
          "Product": "SQL Server",
          "Provider": "MSOLEDBSQL",
          "DataSource": "remote-server.example.local",
          "Catalog": "master",
          "UserId": "linked_user",
          "Password": "linked_password",
          "Rpc": true,
          "RpcOut": true,
          "DataAccess": true
        }
      ]
    },
    "PostClone": {
      "ScriptFolders": [
        "scripts/postclone"
      ]
    },
    "Migration": {
      "Enabled": false,
      "GitRepository": "https://github.com/your-org/your-db-migrations.git",
      "LocalRepositoryPath": "",
      "Branch": "main",
      "BuildCommand": "dotnet ef migrations script --idempotent --project src/App.Data --startup-project src/App.Api --output artifacts/migrate.sql && sqlcmd -S localhost,14333 -d AppDb -U sa -P \"YourStrong!Passw0rd\" -i artifacts/migrate.sql -b",
      "WorkingDirectory": ""
    },
    "Seed": {
      "Enabled": false,
      "Strategy": "BulkCopy",
      "LinkedServerName": "",
      "SourceDatabase": "AppDb",
      "ExcludeSchemas": [],
      "InheritedParentFilterPriorityTables": [],
      "Tables": [
        {
          "SourceDatabase": "AppDb",
          "TargetDatabase": "AppDb",
          "Schema": "dbo",
          "Table": "ReferenceData",
          "TruncateTarget": true,
          "LatestRows": 10000,
          "Order": 10,
          "GroupKey": 1
        }
      ]
    }
  }
}
